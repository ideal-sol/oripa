{
  "name": "@oripa/site-schema",
  "version": "2.0.0-alpha.1",
  "private": true,
  "description": "Public-safeなSite Manifestを検証するAlpha Package。",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "22.22.3",
    "pnpm": "10.12.1"
  },
  "files": [
    "dist",
    "schema"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./schema/site-manifest.schema.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "node scripts/generate-types.mjs --write",
    "generate:check": "node scripts/generate-types.mjs --check",
    "lint": "eslint 'src/**/*.ts' && node --check scripts/generate-types.mjs && node --check test/site-schema.test.mjs",
    "test": "node --test test/site-schema.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@types/semver": "7.7.1",
    "eslint": "10.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0"
  },
  "oripaCompatibility": {
    "family": 2,
    "currentSchemaVersion": "2.0.0-alpha.1",
    "testedSchemaVersions": [
      "2.0.0-alpha.1"
    ],
    "nMinusOneStatus": "pending-first-minor"
  }
}
