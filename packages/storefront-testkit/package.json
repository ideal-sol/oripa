{
  "name": "@oripa/storefront-testkit",
  "version": "2.0.0-alpha.1",
  "private": true,
  "description": "Site StorefrontのPlatform Contract適合を検証する非Production Test Package。",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "22.22.3",
    "pnpm": "10.12.1"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./assertions": {
      "types": "./dist/assertions.d.ts",
      "import": "./dist/assertions.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "import": "./dist/fixtures.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "exports:check": "node scripts/check-exports.mjs",
    "generate": "node scripts/generate-public-contract.mjs --write",
    "generate:check": "node scripts/generate-public-contract.mjs --check",
    "lint": "eslint 'src/**/*.ts' && node --check scripts/check-exports.mjs && node --check scripts/generate-public-contract.mjs && node --check test/testkit.test.mjs",
    "network:check": "node scripts/check-network-boundary.mjs",
    "test": "node --test test/testkit.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oripa/site-schema": "workspace:2.0.0-alpha.1",
    "@oripa/storefront-client": "workspace:2.0.0-alpha.1"
  },
  "devDependencies": {
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.65.0"
  },
  "oripaCompatibility": {
    "family": 2,
    "storefrontClientVersion": "2.0.0-alpha.1",
    "siteSchemaVersion": "2.0.0-alpha.1",
    "publicApiOperationCount": 6
  }
}
