{
  "name": "@oripa/platform-workspace",
  "version": "2.0.0-alpha.1",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "22.22.3",
    "pnpm": "10.12.1"
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "4.3.0",
      "postcss": "8.5.12",
      "sharp": "0.35.0"
    }
  },
  "scripts": {
    "admin:build": "pnpm --filter @oripa/admin build",
    "admin:lint": "pnpm --filter @oripa/admin lint",
    "admin:typecheck": "pnpm --filter @oripa/admin typecheck",
    "openapi:bundle": "python3 scripts/ci/openapi_contract_gate.py --repository . --write-bundles",
    "openapi:check": "python3 scripts/ci/openapi_contract_gate.py --repository . --check-bundles",
    "openapi:test": "python3 -m unittest discover -s tests/ci/openapi -p 'test_*.py'",
    "site-schema:build": "pnpm --filter @oripa/site-schema build",
    "site-schema:check": "pnpm site-schema:generate:check && pnpm site-schema:typecheck && pnpm site-schema:lint && pnpm site-schema:build && pnpm site-schema:test",
    "site-schema:generate": "pnpm --filter @oripa/site-schema generate",
    "site-schema:generate:check": "pnpm --filter @oripa/site-schema generate:check",
    "site-schema:lint": "pnpm --filter @oripa/site-schema lint",
    "site-schema:test": "pnpm --filter @oripa/site-schema test",
    "site-schema:typecheck": "pnpm --filter @oripa/site-schema typecheck",
    "storefront:build": "pnpm --filter @oripa/storefront-client build",
    "storefront:check": "pnpm storefront:generate:check && pnpm storefront:typecheck && pnpm storefront:lint && pnpm storefront:build && pnpm storefront:test",
    "storefront:generate": "pnpm --filter @oripa/storefront-client generate",
    "storefront:generate:check": "pnpm --filter @oripa/storefront-client generate:check",
    "storefront:lint": "pnpm --filter @oripa/storefront-client lint",
    "storefront:test": "pnpm --filter @oripa/storefront-client test",
    "storefront:typecheck": "pnpm --filter @oripa/storefront-client typecheck"
  },
  "devDependencies": {
    "@redocly/cli": "2.40.0"
  }
}
